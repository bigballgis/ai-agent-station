<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ==================== 属性定义 ==================== -->
    <property name="LOG_PATH" value="${LOG_PATH:-logs}" />
    <property name="LOG_FILE" value="${LOG_FILE:-application}" />
    <property name="MAX_FILE_SIZE" value="100MB" />
    <property name="MAX_HISTORY" value="30" />
    <property name="TOTAL_SIZE_CAP" value="3GB" />

    <!-- 控制台日志格式 (开发环境) -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [traceId=%X{traceId}] %-5level %logger{36} - %msg%n" />

    <!-- 文件日志格式 (JSON 风格，生产环境) -->
    <property name="JSON_PATTERN"
              value='{"timestamp":"%d{yyyy-MM-dd'"'"'T'"'"'HH:mm:ss.SSS}","thread":"%thread","traceId":"%X{traceId}","level":"%-5level","logger":"%logger{36}","message":"%msg","exception":"%rEx{full}"}%n' />

    <!-- ==================== 开发环境配置 ==================== -->
    <springProfile name="default | dev | test">

        <!-- 控制台 Appender -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${CONSOLE_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- 开发环境根日志级别 -->
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>

    <!-- ==================== 生产环境配置 ==================== -->
    <springProfile name="prod | production">

        <!-- 控制台 Appender (简洁格式) -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${CONSOLE_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- 文件 Appender (JSON 格式) -->
        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${LOG_FILE}.json.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/${LOG_FILE}.%d{yyyy-MM-dd}.%i.json.log</fileNamePattern>
                <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
                <maxHistory>${MAX_HISTORY}</maxHistory>
                <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${JSON_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <immediateFlush>true</immediateFlush>
        </appender>

        <!-- 生产环境根日志级别 -->
        <root level="WARN">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="JSON_FILE" />
        </root>
    </springProfile>

    <!-- ==================== 通用包级别日志控制 ==================== -->

    <!-- 应用自身日志 -->
    <logger name="com.aiagent" level="INFO" />

    <!-- Spring 框架日志 -->
    <logger name="org.springframework" level="WARN" />
    <logger name="org.springframework.web" level="INFO" />
    <logger name="org.springframework.security" level="WARN" />

    <!-- Hibernate / JPA -->
    <logger name="org.hibernate" level="WARN" />
    <logger name="org.hibernate.SQL" level="WARN" />
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="WARN" />

    <!-- 数据库连接池 -->
    <logger name="com.zaxxer.hikari" level="WARN" />

    <!-- Flyway -->
    <logger name="org.flywaydb" level="INFO" />

    <!-- Redis -->
    <logger name="io.lettuce" level="WARN" />

    <!-- Actuator -->
    <logger name="org.springframework.boot.actuate" level="INFO" />

</configuration>
