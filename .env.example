# ===========================================
# AI Agent Station V3.0 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ===========================================

# ==================== 数据库 ====================
DB_PASSWORD=your_secure_db_password

# ==================== Redis ====================
REDIS_PASSWORD=your_secure_redis_password

# ==================== JWT 认证 ====================
JWT_SECRET=your_very_long_jwt_secret_key_at_least_256_bits
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ==================== LLM Provider 配置 ====================
# 默认 LLM Provider: openai / qwen / ollama
LLM_DEFAULT_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_TIMEOUT=60

# 通义千问配置
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_DEFAULT_MODEL=qwen-plus
QWEN_TIMEOUT=60

# Ollama 本地模型配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2:7b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=4096

# ==================== LangChain4j 配置 ====================
# ChatMemory 窗口大小
LANGCHAIN4J_MEMORY_SIZE=20
# ChatMemory 存储类型: in-memory / redis
LANGCHAIN4J_MEMORY_STORE=in-memory
# Tool Calling 最大迭代次数
LANGCHAIN4J_TOOL_MAX_ITERATIONS=5
# 是否启用 Tool Calling
LANGCHAIN4J_TOOL_CALLING=true
# 文件存储路径 (容器内)
APP_STORAGE_PATH=/app/data/storage
# LLM 请求/响应日志
LLM_LOG_REQUESTS=false
LLM_LOG_RESPONSES=false

# ==================== 监控 ====================
GRAFANA_ADMIN_PASSWORD=your_grafana_password

# ==================== 日志 ====================
LOG_LEVEL=info
